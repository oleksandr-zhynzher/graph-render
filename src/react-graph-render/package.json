{
  "name": "@graph-render/react",
  "version": "1.4.5",
  "description": "Interactive React SVG graph canvas for graph-render.",
  "keywords": [
    "graph",
    "react",
    "svg",
    "visualization",
    "canvas"
  ],
  "homepage": "https://github.com/graph-render/graph-render#readme",
  "bugs": {
    "url": "https://github.com/graph-render/graph-render/issues"
  },
  "author": "graph-render maintainers",
  "private": false,
  "repository": {
    "type": "git",
    "url": "https://github.com/graph-render/graph-render.git",
    "directory": "src/react-graph-render"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org"
  },
  "license": "MIT",
  "type": "module",
  "sideEffects": false,
  "main": "dist/index.js",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist/**/*.d.ts",
    "dist/**/*.js",
    "dist/**/*.map",
    "README.md",
    "CHANGELOG.md",
    "LICENSE"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "dev": "vite",
    "build": "rm -rf dist && vite build && rm -f tsconfig.build.tsbuildinfo && tsc -p tsconfig.build.json --emitDeclarationOnly --declaration",
    "preview": "vite preview",
    "test": "vitest run",
    "lint": "eslint src --ext .ts,.tsx"
  },
  "dependencies": {
    "@graph-render/core": "1.3.5",
    "@graph-render/types": "1.2.5"
  },
  "engines": {
    "node": ">=20.19.0"
  },
  "peerDependencies": {
    "react": "^19.2.6",
    "react-dom": "^19.2.6"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.3.0",
    "@types/react": "^19.2.15",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^6.0.2",
    "jsdom": "^29.1.1",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "typescript": "^6.0.3",
    "vite": "^8.0.13",
    "vitest": "^4.1.7",
    "@vitest/coverage-v8": "^4.1.7"
  }
}
