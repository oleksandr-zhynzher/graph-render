{
  "name": "@graph-render/core",
  "version": "1.3.5",
  "description": "Framework-independent graph layout, routing, validation, and SVG rendering primitives.",
  "keywords": [
    "graph",
    "layout",
    "routing",
    "svg",
    "visualization"
  ],
  "homepage": "https://github.com/graph-render/graph-render#readme",
  "bugs": {
    "url": "https://github.com/graph-render/graph-render/issues"
  },
  "author": "graph-render maintainers",
  "private": false,
  "repository": {
    "type": "git",
    "url": "https://github.com/graph-render/graph-render.git",
    "directory": "src/core-graph-render"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org"
  },
  "type": "module",
  "sideEffects": false,
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist/**/*.d.ts",
    "dist/**/*.js",
    "dist/**/*.map",
    "README.md",
    "CHANGELOG.md",
    "LICENSE"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "license": "MIT",
  "scripts": {
    "build": "rm -rf dist && vite build && rm -f tsconfig.build.tsbuildinfo && tsc -p tsconfig.build.json --emitDeclarationOnly --declaration",
    "test": "vitest run"
  },
  "dependencies": {
    "@graph-render/types": "1.2.5"
  },
  "devDependencies": {
    "@types/node": "^20.10.7",
    "@vitest/coverage-v8": "^3.0.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.3.3",
    "vitest": "^3.0.0"
  }
}
