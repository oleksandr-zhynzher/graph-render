{
  "name": "@graph-render/core",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "src/core-graph-render/src",
  "projectType": "library",
  "targets": {
    "build": {
      "executor": "nx:run-commands",
      "outputs": ["{projectRoot}/dist"],
      "options": {
        "command": "tsc -p tsconfig.json",
        "cwd": "{projectRoot}"
      },
      "dependsOn": ["^build"]
    },
    "lint": {
      "executor": "nx:run-commands",
      "options": {
        "command": "eslint src --ext .ts --ignore-path ../../.eslintignore --max-warnings=0",
        "cwd": "{projectRoot}"
      }
    },
    "format": {
      "executor": "nx:run-commands",
      "options": {
        "command": "prettier --write src",
        "cwd": "{projectRoot}"
      }
    },
    "test": {
      "executor": "nx:run-commands",
      "options": {
        "command": "vitest run",
        "cwd": "{projectRoot}"
      }
    }
  },
  "tags": ["type:library"]
}
