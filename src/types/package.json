{
  "name": "@graph-render/types",
  "version": "1.2.5",
  "description": "Shared TypeScript contracts for graph-render packages.",
  "keywords": [
    "graph",
    "react",
    "typescript",
    "visualization",
    "types"
  ],
  "homepage": "https://github.com/graph-render/graph-render#readme",
  "bugs": {
    "url": "https://github.com/graph-render/graph-render/issues"
  },
  "author": "graph-render maintainers",
  "private": false,
  "repository": {
    "type": "git",
    "url": "https://github.com/graph-render/graph-render.git",
    "directory": "src/types"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org"
  },
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist/**/*.d.ts",
    "dist/**/*.js",
    "dist/**/*.map",
    "README.md",
    "CHANGELOG.md",
    "LICENSE"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./react": {
      "types": "./dist/react.d.ts",
      "import": "./dist/react.js"
    },
    "./tournament": {
      "types": "./dist/tournament.d.ts",
      "import": "./dist/tournament.js"
    }
  },
  "license": "MIT",
  "scripts": {
    "build": "rm -rf dist && vite build && rm -f tsconfig.build.tsbuildinfo && tsc -p tsconfig.build.json --emitDeclarationOnly --declaration",
    "test": "vitest run"
  },
  "peerDependencies": {
    "react": "^19.2.6"
  },
  "peerDependenciesMeta": {
    "react": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/react": "^19.2.15",
    "@vitest/coverage-v8": "^4.1.7",
    "react": "^19.2.6",
    "typescript": "^6.0.3",
    "vitest": "^4.1.7"
  }
}
