{
  "extends": "../../tsconfig.react.json",
  "compilerOptions": {
    "outDir": "./dist",
    "noEmit": false,
    "emitDeclarationOnly": false,
    "allowImportingTsExtensions": false,
    "useDefineForClassFields": true,
    "baseUrl": ".",
    "paths": {
      "@graph-render/react": ["../react-graph-render/dist"],
      "@graph-render/core": ["../core-graph-render/dist"],
      "@graph-render/types": ["../types/dist"]
    }
  },
  "include": ["src"],
  "exclude": ["node_modules", "dist"],
  "references": [{ "path": "./tsconfig.node.json" }]
}
