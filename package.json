{
  "name": "graph-render-monorepo",
  "private": true,
  "workspaces": [
    "src/types",
    "src/core-graph-render",
    "src/react-graph-render",
    "src/react-tournament-tree"
  ],
  "packageManager": "yarn@1.22.22",
  "engines": {
    "node": ">=20.19.0"
  },
  "resolutions": {
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "@types/react": "^19.2.15",
    "@types/react-dom": "^19.0.0",
    "@babel/plugin-transform-modules-systemjs": "^7.29.4",
    "axios": "^1.15.1",
    "fast-uri": "^3.1.1",
    "flatted": "^3.4.0",
    "lodash": "^4.18.1",
    "nx/minimatch": "^9.0.7",
    "**/nx/minimatch": "^9.0.7",
    "@nx/devkit/minimatch": "^9.0.7",
    "**/@nx/devkit/minimatch": "^9.0.7",
    "picomatch": "^4.0.4",
    "rollup": "^4.59.0",
    "storybook": "^10.4.0"
  },
  "scripts": {
    "build:all": "nx run-many -t build",
    "build": "nx run-many -t build",
    "build:affected": "nx affected -t build",
    "test": "nx run-many -t test",
    "test:coverage": "yarn workspace @graph-render/types test -- --coverage && yarn workspace @graph-render/core test -- --coverage && yarn workspace @graph-render/react test -- --coverage && yarn workspace @graph-render/tournament-tree test -- --coverage",
    "audit:high": "node scripts/audit-dependencies.mjs",
    "test:affected": "nx affected -t test",
    "typecheck": "tsc -p tsconfig.typecheck.json",
    "lint": "nx run-many -t lint && eslint -c .eslintrc.react.json .storybook --ext .ts,.tsx --max-warnings=0",
    "lint:strict": "yarn lint",
    "lint:affected": "nx affected -t lint -- --max-warnings=0",
    "quality": "yarn format:check && yarn lint:strict && yarn typecheck && yarn build && yarn test && yarn test:coverage",
    "format": "nx run-many -t format",
    "format:affected": "nx affected -t format",
    "format:all": "prettier --write .",
    "format:check": "prettier --check .",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build",
    "graph": "nx graph",
    "smoke:exports": "node scripts/smoke-package-exports.mjs",
    "prepare": "husky"
  },
  "devDependencies": {
    "@commitlint/cli": "^21.0.1",
    "@commitlint/config-conventional": "^21.0.1",
    "@nx/js": "^22.7.2",
