{
  "compilerOptions": {
    "baseUrl": ".",
    "target": "ES2020",
    "module": "ES2020",
    "lib": ["ES2020"],
    "moduleResolution": "Node",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "paths": {
      "@graph-render/types": ["./src/types/src"],
      "@graph-render/types/*": ["./src/types/src/*"],
      "@graph-render/core": ["./src/core-graph-render/src"],
      "@graph-render/core/*": ["./src/core-graph-render/src/*"],
      "@graph-render/react": ["./src/react-graph-render/src"],
      "@graph-render/react/*": ["./src/react-graph-render/src/*"],
      "@graph-render/tournament-tree": ["./src/react-tournament-tree/src"],
      "@graph-render/tournament-tree/*": ["./src/react-tournament-tree/src/*"]
    },
    "noUnusedLocals": false,
    "noUnusedParameters": false,
    "noImplicitReturns": true,
    "noFallthroughCasesInSwitch": true
  }
}
